---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/blog">SOLUTIONS</HeaderLink>
			<HeaderLink href="/blog">PROJECTS</HeaderLink>
			<HeaderLink href="/about">MEDIA</HeaderLink>
			<HeaderLink href="/about">COMPANY</HeaderLink>
			<HeaderLink href="/">LOGIN</HeaderLink>
		</div>
		<div class="user-icon" aria-hidden="true">●</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 2em;
		background: transparent;
	}

	h2 {
		margin: 0;
		font-size: 1em;
		color: white;
		letter-spacing: 0.08em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
		color: white;
		font-size: 2rem;
		font-weight: 700;
		line-height: 1;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1280px;
		margin: 0 auto;
		padding: 1.2em 0 0.5em;
		gap: 1.2em;
	}

	nav a {
		padding: 0.5em;
		color: white;
		text-decoration: none;
		font-size: 0.83rem;
		letter-spacing: 0.06em;
	}

	.internal-links {
		display: flex;
		gap: 1em;
		margin-left: auto;
	}

	.internal-links :global(a.active) {
		color: #f6a24d;
		font-weight: 700;
		text-decoration: none;
		border-bottom: none;
	}

	.user-icon {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: #ffffff;
		opacity: 0.9;
		margin-left: 0.25em;
		color: transparent;
		overflow: hidden;
	}

	@media (max-width: 720px) {
		.internal-links {
			display: none;
		}

		nav {
			padding-top: 1em;
		}

		h2 a,
		h2 a.active {
			font-size: 1.55rem;
		}
	}
</style>
