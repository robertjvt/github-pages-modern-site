---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-panel">
					<h1>SMART ASSET MANAGEMENT<br /><span>SAFE AND ACCURATE</span></h1>
					<p>Collecting, analyzing and providing insights</p>
					<a href="/about" class="cta">Learn more</a>
				</div>
			</section>

			<section class="services">
				<article class="service-card">
					<h3>INSPECTION<br />SERVICES</h3>
					<div class="line"></div>
					<p>
						Supporting the digital transformation of assets management with smart automated data gathering methods and remote viewing.
					</p>
				</article>
				<article class="service-card">
					<h3>DATA SERVICES</h3>
					<div class="line"></div>
					<p>
						Including point clouds, meshes, 3D modelling and digital twins for intelligence and consulting services.
					</p>
				</article>
				<article class="service-card">
					<h3>MAPPING &amp; GEO<br />SERVICES</h3>
					<div class="line"></div>
					<p>
						Surveying at scale with precision measurements and creation of digital terrain models for projects.
					</p>
				</article>
				<article class="service-card">
					<h3>FILM &amp;<br />PHOTOGRAPHY</h3>
					<div class="line"></div>
					<p>
						Experienced with challenging conditions and visual requirements for company videos and commercials.
					</p>
				</article>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		margin-top: 1.3rem;
		min-height: 370px;
		display: flex;
		align-items: flex-start;
		padding: 1.1rem 0 0.3rem;
	}

	.hero-panel {
		width: min(730px, 100%);
		background: linear-gradient(120deg, rgba(9, 14, 31, 0.88), rgba(10, 16, 38, 0.48));
		border: 1px solid rgba(255, 255, 255, 0.08);
		padding: 2.9rem 2.5rem 2.35rem;
	}

	.hero h1 {
		font-size: clamp(2rem, 4.2vw, 3.36rem);
		font-weight: 400;
		letter-spacing: 0.02em;
		margin: 0 0 0.3em;
		line-height: 1.1;
	}

	.hero h1 span {
		color: #f39a3e;
	}

	.hero p {
		margin: 0.3rem 0 1.9rem;
		font-size: 1.95rem;
		color: rgba(241, 246, 255, 0.94);
	}

	.cta {
		display: inline-block;
		padding: 0.75rem 2.2rem;
		border: 1px solid #c37a37;
		border-radius: 999px;
		color: #f3f6ff;
		text-decoration: none;
		font-size: 1.05rem;
	}

	.services {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1.25rem;
		margin-top: 2.8rem;
	}

	.service-card {
		background: linear-gradient(170deg, rgba(16, 21, 43, 0.82), rgba(8, 13, 29, 0.9));
		border: 1px solid rgba(255, 255, 255, 0.08);
		padding: 1.45rem 1.2rem 1.2rem;
		min-height: 262px;
	}

	.service-card h3 {
		font-size: 2rem;
		line-height: 1;
		letter-spacing: 0.01em;
	}

	.line {
		width: 48px;
		height: 4px;
		background: #204f9a;
		margin: 0.8rem 0 1rem;
	}

	.service-card p {
		margin: 0;
		color: rgba(223, 230, 247, 0.9);
		font-size: 1.25rem;
		line-height: 1.42;
	}

	@media (max-width: 1100px) {
		.services {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 720px) {
		.hero {
			min-height: auto;
		}

		.hero-panel {
			padding: 1.5rem 1.1rem;
		}

		.hero p {
			font-size: 1.1rem;
		}

		.services {
			grid-template-columns: 1fr;
			margin-top: 1.7rem;
		}
	}
</style>
